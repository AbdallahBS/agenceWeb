{
  "info": {
    "name": "Agence Voyage - Admin & Client Auth Checks",
    "description": "Collection pour verifier register/login/me/logout pour client/admin et le flux forgot/reset password par email.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "clientEmail", "value": "abenssalem32@gmail.com" },
    { "key": "clientPassword", "value": "secret123" },
    { "key": "clientToken", "value": "" },
    { "key": "clientId", "value": "" },
    { "key": "adminEmail", "value": "admin@example.com" },
    { "key": "adminPassword", "value": "admin123" },
    { "key": "adminToken", "value": "" },
    { "key": "resetToken", "value": "COLLER_TOKEN_RECU_PAR_EMAIL" }
  ],
  "item": [
    {
      "name": "01 - Health check",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('Contains message', () => pm.expect(j).to.have.property('message'));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
      }
    },
    {
      "name": "Client Auth",
      "item": [
        {
          "name": "02 - Register client (expect 201)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.test('Token present', () => pm.expect(j.token).to.be.a('string'));",
                  "pm.test('Role is client', () => pm.expect(j.role).to.eql('client'));",
                  "pm.collectionVariables.set('clientToken', j.token);",
                  "pm.collectionVariables.set('clientId', j._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prenom\": \"Client\",\n  \"nom\": \"Test\",\n  \"email\": \"{{clientEmail}}\",\n  \"password\": \"{{clientPassword}}\",\n  \"genre\": \"homme\",\n  \"cin\": \"11112222\",\n  \"telephone\": \"+21600000011\",\n  \"dateNaissance\": \"1999-01-01\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "03 - Login client (expect 200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('Token returned', () => pm.expect(j.token).to.be.a('string'));",
                  "pm.test('Role is client', () => pm.expect(j.role).to.eql('client'));",
                  "pm.collectionVariables.set('clientToken', j.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{clientEmail}}\",\n  \"password\": \"{{clientPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "04 - Me with client token (expect 200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('Email matches', () => pm.expect(j.email).to.eql(pm.collectionVariables.get('clientEmail')));",
                  "pm.test('Role is client', () => pm.expect(j.role).to.eql('client'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Auth",
      "item": [
        {
          "name": "05 - Login admin (expect 200 only if admin exists)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 401', () => pm.expect([200, 401]).to.include(pm.response.code));",
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  pm.test('Role is admin', () => pm.expect(j.role).to.eql('admin'));",
                  "  pm.collectionVariables.set('adminToken', j.token);",
                  "} else {",
                  "  pm.test('Admin account likely missing', () => true);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "06 - Me with admin token (run only if previous was 200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 401', () => pm.expect([200, 401]).to.include(pm.response.code));",
                  "if (pm.response.code === 200) {",
                  "  const j = pm.response.json();",
                  "  pm.test('Role is admin', () => pm.expect(j.role).to.eql('admin'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Logout & Reset Password",
      "item": [
        {
          "name": "07 - Logout client (expect 200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        },
        {
          "name": "07b - Logout admin (expect 200 if admin token exists, else 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 401', () => pm.expect([200, 401]).to.include(pm.response.code));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        },
        {
          "name": "08 - Forgot password client (expect 200 + email sent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('Generic success message returned', () => pm.expect(j).to.have.property('message'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{clientEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "forgot-password"]
            }
          }
        },
        {
          "name": "09 - Reset password client with token from email (expect 200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"newSecret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/reset-password/{{resetToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "reset-password", "{{resetToken}}"]
            }
          },
          "description": "Apres la requete forgot-password, recuperez le token dans l'email puis collez-le dans la variable collection resetToken."
        }
      ]
    }
  ]
}
